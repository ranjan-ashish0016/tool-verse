# GEMINI_API_KEY: Required for Gemini AI API calls (Server side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Injectable self-referential app URL
APP_URL="MY_APP_URL"

# --- MongoDB Database Variable ---
# If left blank, the app runs with a fully functional file-based or in-memory persistence fallback
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/otp_login_db"

# --- JSON Web Token Secret ---
# Used for cryptographically signing sessions
JWT_SECRET="super-secret-temporary-jwt-key"

# --- Nodemailer SMTP Server Configuration ---
# Leave these empty to enable "Development Simulator Mode" where OTPs are displayed
# on-screen via developer notification helper and logged to server output.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-use-app-password-not-real-password"

