{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account registration details stored on initial sign up.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier of the user (matching Firebase Auth UID)."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp indicating when the user was created."
        }
      },
      "required": ["uid", "fullName", "email", "createdAt"]
    },
    "GstHistory": {
      "title": "GST Calculation History",
      "description": "GST calculations completed by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "rate": { "type": "number" },
        "type": { "type": "string" },
        "gstAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "rate", "type", "gstAmount", "totalAmount", "createdAt"]
    },
    "EmiHistory": {
      "title": "EMI Calculation History",
      "description": "EMI calculations completed by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "principal": { "type": "number" },
        "rate": { "type": "number" },
        "tenure": { "type": "number" },
        "monthlyEmi": { "type": "number" },
        "totalInterest": { "type": "number" },
        "totalPayment": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "principal", "rate", "tenure", "monthlyEmi", "totalInterest", "totalPayment", "createdAt"]
    },
    "AgeHistory": {
      "title": "Age Calculation History",
      "description": "Age calculations completed by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "birthDate": { "type": "string" },
        "targetDate": { "type": "string" },
        "years": { "type": "number" },
        "months": { "type": "number" },
        "days": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "birthDate", "targetDate", "years", "months", "days", "createdAt"]
    },
    "QrHistory": {
      "title": "QR Generation History",
      "description": "QR codes generated by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "foregroundColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "size": { "type": "number" },
        "qrImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "qrImageUrl", "createdAt"]
    },
    "PasswordHistory": {
      "title": "Password Generation History",
      "description": "Generated passwords saved in history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "length": { "type": "number" },
        "strength": { "type": "string" },
        "hasUppercase": { "type": "boolean" },
        "hasLowercase": { "type": "boolean" },
        "hasNumbers": { "type": "boolean" },
        "hasSymbols": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "length", "strength", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores core registered user metadata details."
    },
    "/gst_history/{docId}": {
      "schema": "GstHistory",
      "description": "Tracks historic GST calculations."
    },
    "/emi_history/{docId}": {
      "schema": "EmiHistory",
      "description": "Tracks historic EMI calculations."
    },
    "/age_history/{docId}": {
      "schema": "AgeHistory",
      "description": "Tracks historic age-related calculation states."
    },
    "/qr_history/{docId}": {
      "schema": "QrHistory",
      "description": "Tracks user generated barcodes / QR patterns."
    },
    "/password_history/{docId}": {
      "schema": "PasswordHistory",
      "description": "Stores non-plain-text custom meta indicators for passwords."
    }
  }
}
